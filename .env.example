# ============================================
# UMAMIDO LOYALTY — Variables d'environnement
# ============================================
# Copie ce fichier en .env et remplis les valeurs

# Serveur
PORT=3000
BASE_URL=https://ton-projet.railway.app

# Apple Developer (à remplir après avoir le compte)
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_PASS_TYPE_ID=pass.com.umamido.loyalty
APPLE_CERT_PATH=./certs/pass.pem
APPLE_KEY_PATH=./certs/pass.key
APPLE_KEY_PASSPHRASE=ton-mot-de-passe-cert
APPLE_WWDR_PATH=./certs/wwdr.pem

# Sécurité
SECRET_KEY=umamido-secret-change-moi-en-prod

# Base de données
DB_PATH=./umamido.db
